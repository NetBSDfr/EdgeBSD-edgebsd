#variables
BOOTLOADER=0
DESTDIR="/"
DEVNULL="/dev/null"
EDGEBSD_ARCH=$(uname -m)
EDGEBSD_KERNEL="GENERIC"
EDGEBSD_MIRROR="ftp://ftp.edgebsd.org"
EDGEBSD_PATH=
EDGEBSD_RELEASE=$(uname -r)
EDGEBSD_RELEASE="EdgeBSD-${EDGEBSD_RELEASE%.*}"
ETCMTREE="/etc/mtree"
KERNEL=0
MODULES=0
NOOP=0
PACKAGES=0
PROGNAME="edgebsd-update"
SETEXT=".tgz"
SETS=
[ -n "$TMPDIR" ] || TMPDIR="/tmp"
UPDATE_ETC=0
USRMDECBOOT="/usr/mdec/boot"
VERBOSE=1
VERIFY=1
VERIFY_USERID="root@edgebsd.org"
#executables
CP="/bin/cp -a"
DEBUG="_debug"
FTP="/usr/bin/ftp -V"
GZIP="/usr/bin/gzip -9"
INSTALL="/usr/bin/install"
MKDIR="/bin/mkdir -p"
MKTEMP="/usr/bin/mktemp $TMPDIR/$PROGNAME-XXXXXX"
MOUNT="/sbin/mount"
NETPGP="/usr/bin/netpgp"
NETPGPKEYS="/usr/bin/netpgpkeys"
PAXCTL="/usr/sbin/paxctl"
PKGIN="/usr/pkg/bin/pkgin"
POSTINSTALL="/usr/sbin/postinstall"
PROGRESS="/usr/bin/progress"
RM="/bin/rm -f"
TAR="/rescue/tar"
UMOUNT="/sbin/umount"


#functions
#architecture-specific
_arch_amd64_update_bootloader()
{
	_arch_i386_update_bootloader
}

_arch_amd64_update_kernel()
{
	_arch_i386_update_kernel
}

_arch_evbarm_update_bootloader()
{
	#XXX assumes the Raspberry PI and DESTDIR=/
	#FIXME replace the firmware content if available
	return 0
}

_arch_evbarm_update_kernel()
{
	ret=0

	#XXX assumes the Raspberry PI and DESTDIR=/
	if ! $MOUNT "$DESTDIR/boot"; then
		_error "$EDGEBSD_KERNEL: Could not mount the boot partition"
		return $?
	fi
	file="kern-${EDGEBSD_KERNEL}${SETEXT}"
	[ -z "${EDGEBSD_MIRROR##/*}" ] && file="$EDGEBSD_PATH/$file"
	if [ $VERIFY -ne 0 ]; then
		_info "Verifying kernel ${EDGEBSD_KERNEL}..."
		_verify "$file"
		if [ $? -ne 0 ]; then
			_error "$EDGEBSD_KERNEL: Could not verify the kernel"
			exit $?
		fi
	fi
	#backup the current kernel
	if [ -f "$DESTDIR/boot/kernel7.img" ]; then
		$CP -- "$DESTDIR/boot/kernel7.img" "$DESTDIR/boot/okernel7.img"
		if [ $? -ne 0 ]; then
			_error "$EDGEBSD_KERNEL: Could not backup the kernel"
			exit $?
		fi
	fi
	_info "Installing kernel ${EDGEBSD_KERNEL}..."
	$DEBUG $PROGRESS -f "$file" $TAR -xzpf - -C "$DESTDIR/boot"
	if [ $? -ne 0 ]; then
		_error "$EDGEBSD_KERNEL: Could not install the kernel"
		exit $?
	fi
	_info "Renaming kernel ${EDGEBSD_KERNEL}..."
	$DEBUG $MV -f -- "$DESTDIR/boot/netbsd.bin" "$DESTDIR/boot/kernel7.img"
	if [ $? -ne 0 ]; then
		_error "$EDGEBSD_KERNEL: Could not rename the kernel"
		exit $?
	fi
	ret=$?
	$UMOUNT "$DESTDIR/boot"
	[ $? -ne 0 ] && _error "$EDGEBSD_KERNEL: Could not unmount the boot partition"
	return $ret
}

_arch_generic_update_bootloader()
{
	#XXX is this always the case?
	if [ -f "$DESTDIR/boot" -a -f "$DESTDIR$USRMDECBOOT" ]; then
		$INSTALL -m 0444 "$DESTDIR$USRMDECBOOT" "$DESTDIR/boot"
		#FIXME also use installboot(8) when appropriate
	fi
}

_arch_generic_update_kernel()
{
	file="kern-${EDGEBSD_KERNEL}${SETEXT}"
	[ -z "${EDGEBSD_MIRROR##/*}" ] && file="$EDGEBSD_PATH/$file"
	if [ $VERIFY -ne 0 ]; then
		_info "Verifying kernel ${EDGEBSD_KERNEL}..."
		_verify "$file"
		if [ $? -ne 0 ]; then
			_error "$EDGEBSD_KERNEL: Could not verify the kernel"
			exit $?
		fi
	fi
	#backup the current kernel
	if [ -f "$DESTDIR/netbsd.gz" ]; then
		$CP -- "$DESTDIR/netbsd.gz" "$DESTDIR/onetbsd.gz"
		if [ $? -ne 0 ]; then
			_error "$EDGEBSD_KERNEL: Could not backup the kernel"
			exit $?
		fi
	fi
	_info "Installing kernel ${EDGEBSD_KERNEL}..."
	$DEBUG $PROGRESS -f "$file" $TAR -xzpf - -C "$DESTDIR"
	if [ $? -ne 0 ]; then
		_error "$EDGEBSD_KERNEL: Could not install the kernel"
		exit $?
	fi
	_info "Compressing kernel ${EDGEBSD_KERNEL}..."
	$DEBUG $GZIP -f -- "$DESTDIR/netbsd"
	if [ $? -ne 0 ]; then
		_error "$EDGEBSD_KERNEL: Could not compress the kernel"
		exit $?
	fi
}

_arch_i386_update_bootloader()
{
	_arch_generic_update_bootloader
}

_arch_i386_update_kernel()
{
	_arch_generic_update_kernel
}

_arch_sparc_update_bootloader()
{
	_arch_generic_update_bootloader
}

_arch_sparc_update_kernel()
{
	_arch_generic_update_kernel
}

_arch_sparc64_update_bootloader()
{
	_arch_sparc_update_bootloader
}

_arch_sparc64_update_kernel()
{
	_arch_sparc_update_kernel
}


#debug
_debug()
{
	[ $VERBOSE -ge 3 ] && echo "$@" 1>&2
	"$@"
}


#download
_download()
{
	file="$1"

	$DEBUG $FTP "$EDGEBSD_PATH/$file"
	res=$?
	[ $res -eq 0 ] || $RM -- "$file"
	return $res
}


#error
_error()
{
	echo "$PROGNAME: $@" 1>&2
	return 2
}


#import_gpg_key
_import_gpg_key()
{
	ret=0

	tmpfile=$($MKTEMP)
	[ $? -eq 0 ]						|| return 2
	_import_gpg_key_echo > "$tmpfile" &&
	$NETPGPKEYS --import-key "$tmpfile" > "$DEVNULL"	|| ret=2
	$RM -- "$tmpfile"
	return $ret
}


