#info
_info()
{
	[ $VERBOSE -ge 1 ] && echo "$@" 1>&2
}


#usage
_usage()
{
	echo "Usage: $PROGNAME [-BbKkmnpqSsv][-M mirror][-P path]" 1>&2
	echo "  -P	Full path to the sets"
	echo "  -B	Do not update the bootloader"
	echo "  -b	Update the bootloader"
	echo "  -K	Do not update the kernel"
	echo "  -k	Update the kernel"
	echo "  -M	Specify a different mirror when downloading"
	echo "  -m	Update the kernel modules"
	echo "  -n	Download the sets but do not install them"
	echo "  -p	Update the packages"
	echo "  -q	Enable quiet mode"
	echo "  -S	Do not verify signatures"
	echo "  -s	Verify signatures (default)"
	echo "  -v	Be more verbose"
	return 1
}


#verify
_verify()
{
	file="$1"

	$NETPGP --verify --userid "$VERIFY_USERID" "${file}.sig"
}


#main
#parse arguments
while getopts "O:M:P:BbKkmnpqSsv" name; do
	case "$name" in
		O)
			export "${OPTARG%%=*}"="${OPTARG#*=}"
			;;
		P)
			EDGEBSD_PATH="$OPTARG"
			;;
		B)
			BOOTLOADER=0
			;;
		b)
			BOOTLOADER=1
			;;
		K)
			KERNEL=0
			;;
		k)
			KERNEL=1
			;;
		M)
			EDGEBSD_MIRROR="$OPTARG"
			;;
		m)
			MODULES=1
			;;
		n)
			NOOP=1
			;;
		p)
			PACKAGES=1
			;;
		q)
			FTP="/usr/bin/ftp -V"
			VERBOSE=0
			;;
		S)
			VERIFY=0
			;;
		s)
			VERIFY=1
			;;
		v)
			VERBOSE=$((VERBOSE + 1))
			[ $VERBOSE -ge 2 ] && FTP="/usr/bin/ftp"
			;;
		*)
			_usage
			exit $?
			;;
	esac
done
shift $((OPTIND - 1))
if [ $# -ne 0 ]; then
	_usage
	exit $?
fi

if [ $VERIFY -ne 0 ]; then
	#import the GPG key
	_info "Importing the GPG key..."
	#FIXME does not work
	_import_gpg_key						|| return 2
fi

#detect the sets to update
if [ -z "$SETS" ]; then
	for i in "$DESTDIR$ETCMTREE/set."*; do
		set="${i#$DESTDIR$ETCMTREE/set.}"
		[ -n "$set" ] && SETS="$SETS $set"
	done
fi

if [ $MODULES -ne 0 ]; then
	has_stand=0
	for i in $SETS; do
		[ "$i" = "stand" ] && has_stand=1
	done
	[ $has_stand -eq 0 ] && SETS="$SETS stand"
fi

if [ -z "$EDGEBSD_PATH" ]; then
	EDGEBSD_PATH="$EDGEBSD_MIRROR/pub/EdgeBSD/$EDGEBSD_RELEASE/$EDGEBSD_ARCH/binary/sets"
else
	EDGEBSD_MIRROR="/nonexistent"
fi

#download the kernel
if [ $KERNEL -ne 0 -a -n "${EDGEBSD_MIRROR##/*}" ]; then
	if [ ! -f "kern-${EDGEBSD_KERNEL}${SETEXT}" ]; then
		_info "Downloading kernel ${EDGEBSD_KERNEL}..."
		_download "kern-${EDGEBSD_KERNEL}${SETEXT}"
		if [ $? -ne 0 ]; then
			_error "$EDGEBSD_KERNEL: Could not download the kernel"
			exit $?
		fi
	fi
	if [ $VERIFY -ne 0 -a ! -f "kern-${EDGEBSD_KERNEL}${SETEXT}.sig" ]; then
		_info "Downloading signature for kernel ${EDGEBSD_KERNEL}..."
		_download "kern-${EDGEBSD_KERNEL}${SETEXT}.sig"
		if [ $? -ne 0 ]; then
			_error "$EDGEBSD_KERNEL: Could not download the kernel signature"
			exit $?
		fi
	fi
fi

#download the relevant sets
res=0
for set in $SETS; do
	[ -z "${EDGEBSD_MIRROR##/*}" ] && continue
	[ -f "${set}${SETEXT}" ] && continue
	_info "Downloading set ${set}..."
	_download "${set}${SETEXT}"
	res=$?
	[ $res -eq 0 ] || break
	[ $VERIFY -eq 0 ] && continue
	_info "Downloading signature for set ${set}..."
	_download "${set}${SETEXT}.sig"
	res=$?
	[ $res -eq 0 ] || break
done
if [ $res -ne 0 ]; then
	_error "$set: Could not download the set"
	[ -f "${set}${SETEXT}" ] && $RM -- "${set}${SETEXT}"
	exit $?
fi

[ $NOOP -ne 0 ] && exit 0

#install the kernel
if [ $KERNEL -ne 0 ]; then
	_info "Updating the kernel..."
	case "$EDGEBSD_ARCH" in
		amd64|evbarm|i386|sparc|sparc64)
			"_arch_${EDGEBSD_ARCH}_update_kernel"
			res=$?
			;;
		*)
			res=2
			;;
	esac
fi

#install the relevant sets
$MKDIR -- "$DESTDIR"
for set in $SETS; do
	if [ "$set" = "etc" ]; then
		UPDATE_ETC=1
		#skip the "etc" set if already installed
		[ -f "$DESTDIR$ETCMTREE/set.$set" ] && continue
	fi
	file="${set}${SETEXT}"
	[ -z "${EDGEBSD_MIRROR##/*}" ] && file="$EDGEBSD_PATH/$file"
	if [ $VERIFY -ne 0 ]; then
		_info "Verifying set ${set}..."
		_verify "$file"
		res=$?
		[ $res -eq 0 ] || break
	fi
	_info "Installing set ${set}..."
	$DEBUG $PROGRESS -f "$file" $TAR -xzpf - -C "$DESTDIR"
	res=$?
	[ $res -eq 0 ] || break
done
if [ $res -ne 0 ]; then
	_error "$set: Could not install the set"
	exit $?
fi

#update the configuration
if [ $UPDATE_ETC -eq 1 ]; then
	set="etc"
	file="${set}${SETEXT}"
	[ -z "${EDGEBSD_MIRROR##/*}" ] && file="$EDGEBSD_PATH/$file"
	if [ $VERIFY -ne 0 ]; then
		_info "Verifying set ${set}..."
		_verify "$file"
		res=$?
		[ $res -eq 0 ] || break
	fi
	_info "Configuring the system..."
	$DEBUG $POSTINSTALL -s "$file" -d "$DESTDIR" fix > "$DEVNULL"
	res=$?
	#XXX fix /usr/libexec/cc1*
	if [ $res -eq 0 -a -x "$PAXCTL" ]; then
		for i in cc1 cc1obj cc1plus; do
			if [ -x "$DESTDIR/usr/libexec/$i" ]; then
				$PAXCTL +m "$DESTDIR/usr/libexec/$i"
				res=$?
			fi
			[ $res -eq 0 ] || break
		done
	fi
fi
if [ $res -ne 0 ]; then
	_error "Could not update the configuration"
	exit $?
fi

#update the packages
if [ $PACKAGES -ne 0 ]; then
	_info "Updating the packages..."
	if [ -n "$DESTDIR" ]; then
		$PKGIN -y -c "$DESTDIR" full-upgrade
	else
		$PKGIN -y full-upgrade
	fi
	if [ $? -ne 0 ]; then
		_error "$set: Could not update the packages"
		exit $?
	fi
fi

#update the bootloader
if [ $BOOTLOADER -ne 0 ]; then
	_info "Updating the bootloader..."
	case "$EDGEBSD_ARCH" in
		amd64|evbarm|i386|sparc|sparc64)
			"_arch_${EDGEBSD_ARCH}_update_bootloader"
			res=$?
			;;
		*)
			res=2
			;;
	esac
	if [ $res -ne 0 ]; then
		_error "Could not update the bootloader"
		exit $?
	fi
fi

#clean the sets
for set in $SETS; do
	[ -z "${EDGEBSD_MIRROR##/*}" ] && continue
	_info "Removing downloaded set ${set}..."
	[ $VERIFY -ne 0 ] && $RM -- "${set}${SETEXT}.sig"
	$RM -- "${set}${SETEXT}"
done
if [ $KERNEL -ne 0 -a -n "${EDGEBSD_MIRROR##/*}" ]; then
	[ $VERIFY -ne 0 ] && $RM -- "kern-${EDGEBSD_KERNEL}${SETEXT}.sig"
	$RM -- "kern-${EDGEBSD_KERNEL}${SETEXT}"
fi

_info "Update successful."
