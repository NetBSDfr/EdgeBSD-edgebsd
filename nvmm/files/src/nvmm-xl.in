#nvmm_xl_reboot
_nvmm_xl_reboot()
{
	while getopts "O:qv" name; do
		case "$name" in
			O)
				eval "${OPTARG%%=*}"="${OPTARG#*=}"
				;;
			q)
				VERBOSE=0
				;;
			v)
				VERBOSE=$((VERBOSE + 1))
				;;
			*)
				_usage
				return $?
