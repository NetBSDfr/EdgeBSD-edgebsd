#variables
#executables
CAT="cat"
DEBUG=
MKDIR="mkdir"
NC="nc"
NVMMCTL="/usr/sbin/nvmmctl"
QEMU="@BINDIR@/qemu-system-x86_64 -nographic"
SCREEN="screen"
#settings
DEVNULL="/dev/null"
PREFIX="@PREFIX@"
PROGNAME="nvmm-xl"
RUNDIR="/var/run/nvmm"
SCREENDIR="/tmp/screens"
SYSCONFDIR="@SYSCONFDIR@"
USER="$(id -un)"

#load local settings
[ -f "$SYSCONFDIR/nvmm/$PROGNAME.conf" ] &&
	. "$SYSCONFDIR/nvmm/$PROGNAME.conf"
[ -f "$HOME/.config/nvmm/$PROGNAME.conf" ] &&
	. "$HOME/.config/nvmm/$PROGNAME.conf"


#functions
#debug
_debug()
{
	echo "$@" 1>&2
	"$@"
}


#error
_error()
{
	echo "$PROGNAME: $@" 1>&2
	return 2
}


#nvmm_xl
_nvmm_xl()
{
	while getopts "O:" name; do
		case "$name" in
			O)
				eval "${OPTARG%%=*}"="${OPTARG#*=}"
				;;
			*)
				_usage
				return $?
				;;
		esac
	done
	shift $((OPTIND - 1))
	if [ $# -eq 0 ]; then
		_usage
		return $?
	fi
	command="$1"
	shift
	case "$command" in
		console|create|destroy|list|shutdown)
			"_nvmm_xl_$command" "$@"
			return $?
			;;
		*)
			_usage "$command: Unknown command"
			return $?
			;;
	esac
}


#nvmm_xl_command
_nvmm_xl_command()
{
	domain="$1"
	socket="$RUNDIR/$domain"
	shift

	echo "$@" | $DEBUG $NC -U "$socket" > "$DEVNULL"
}


#nvmm_xl_console
_nvmm_xl_console()
{
	while getopts "" name; do
		case "$name" in
			*)
				_usage
				return $?
				;;
		esac
	done
	shift $((OPTIND - 1))
	if [ $# -ne 1 ]; then
		_usage "console: A domain is required"
		return $?
	fi
	domain="$1"
	session="_nvmm-$domain"

	for s in "$SCREENDIR/S-$USER/"*"._nvmm-"*; do
		[ -S "$s" ] || continue
		if [ "${s#$SCREENDIR/S-$USER/*.}" = "$session" ]; then
			$DEBUG $SCREEN -x "$session"
			return $?
		fi
	done
	_error "$domain: Domain not available"
	return $?1
}


#nvmm_xl_create
_nvmm_xl_create()
{
	console=0
	while getopts "c" name; do
		case "$name" in
			c)
				console=1
				;;
			*)
				_usage
				return $?
				;;
		esac
	done
	shift $((OPTIND - 1))
	if [ $# -ne 1 ]; then
		_usage "create: A configuration file is required"
		return $?
	fi
	filename="$1"

	if [ ! -f "$filename" ]; then
		_error "$filename: Domain not configured"
		return $?
	fi

	domain="${filename##*/}"
	lineno=0
	section=
	#variables
	qemu_machine="accel=nvmm"
	qemu_memory="128M"
	qemu_vcpus="1"
	while read line; do
		lineno=$((lineno + 1))
		case "$line" in
			"#"*)
				;;
			"["*"]")
				section="${line#?}"
				section="${section%?}"
				;;
			*=*)
				variable="${line%%=*}"
				value="${line#*=}"
				case "$section::$variable" in
					"::machine")
						qemu_machine="$value"
						;;
					"::memory")
						qemu_memory="$value"
						;;
					"::name")
						#FIXME validate (no "/")
						domain="$value"
						;;
					"::vcpus")
						qemu_vcpus="$value"
						;;
					"::args")
						qemu_args="$value"
						;;
					*)
						_error "$section::$variable: Unknown variable"
						return $?
						;;
				esac
				;;
			*)
				_error "$filename:$lineno: Parse error"
				return $?
				;;
		esac
	done < "$filename"

	session="_nvmm-$domain"
	socket="$RUNDIR/$domain"
	screen_args=
	[ $console -eq 0 ] && screen_args="-d -m"

	$DEBUG $MKDIR -p -m 0700 "${socket%/*}"
	if [ $? -ne 0 ]; then
		_error "$socket: Could not create the socket"
		return $?
	fi
	if [ -S "$socket" ]; then
		_error "$domain: Virtual Machine already running"
		return $?
	fi
	$DEBUG $SCREEN -S "$session" $screen_args \
		$QEMU -machine "$qemu_machine" -chardev stdio,id=s1,signal=off \
		-serial none -device isa-serial,chardev=s1 \
		-chardev "socket,id=mon0,path=$socket,server,nowait" \
		-mon "chardev=mon0,mode=readline" \
		-name "$domain" -m "$qemu_memory" -smp "$qemu_vcpus" \
		$qemu_args
}


#nvmm_xl_destroy
_nvmm_xl_destroy()
{
	while getopts "" name; do
		case "$name" in
			*)
				_usage
				return $?
				;;
		esac
	done
	shift $((OPTIND - 1))
	if [ $# -ne 1 ]; then
		_usage "destroy: A domain is required"
		return $?
	fi
	domain="$1"

	_nvmm_xl_command "$domain" "quit"
}


#nvmm_xl_list
_nvmm_xl_list()
{
	#XXX output more information about each domain
	echo "Name"
	echo "NVMM"
	for domain in "$SCREENDIR/S-$USER/"*"._nvmm-"*; do
		[ -S "$domain" ] || continue
		echo "${domain##*._nvmm-}"
	done
}


#nvmm_xl_shutdown
_nvmm_xl_shutdown()
{
	fallback=0
	while getopts "F" name; do
		case "$name" in
			F)
				#XXX implement
				fallback=1
				;;
			*)
				_usage
				return $?
				;;
		esac
	done
	shift $((OPTIND - 1))
	if [ $# -ne 1 ]; then
		_usage "shutdown: A domain is required"
		return $?
	fi
	domain="$1"

	_nvmm_xl_command "$domain" "system_powerdown"
}


#usage
_usage()
{
	[ $# -ge 1 ] && echo "$PROGNAME: $@" 1>&2
	echo "Usage: $PROGNAME command [options...]" 1>&2
	echo 1>&2
	echo "Commands supported:" 1>&2
	echo "  console	Attach the console of a Virtual Machine instance" 1>&2
	echo "  create [-c]	Start a Virtual Machine instance" 1>&2
	echo "  destroy	Power off a Virtual Machine instance" 1>&2
	echo "  list		List the Virtual Machine instances available" 1>&2
	echo "  shutdown [-F]	Stop a Virtual Machine instance gracefully" 1>&2
	return 1
}


#main
_nvmm_xl "$@"
