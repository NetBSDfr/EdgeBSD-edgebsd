	<refsect1 id="description">
		<title>Description</title>
		<para>
			&name; manages Virtual Machine instances with NVMM.
		</para>
	</refsect1>
	<refsect1 id="options">
		<title>Options</title>
		<para>The following commands are available:</para>
		<variablelist>
