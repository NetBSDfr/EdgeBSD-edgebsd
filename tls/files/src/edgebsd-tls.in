#variables
#executables
OPENSSL="openssl"
#settings
PREFIX="@PREFIX@"
PROGNAME="edgebsd-tls"
SYSCONFDIR="@SYSCONFDIR@"
VENDOR="EdgeBSD"

#load local settings
[ -f "$SYSCONFDIR/$VENDOR/$PROGNAME.conf" ] &&
	. "$SYSCONFDIR/$VENDOR/$PROGNAME.conf"
[ -n "$HOME" -a -f "$HOME/.config/$VENDOR/$PROGNAME.conf" ] &&
	. "$HOME/.config/$VENDOR/$PROGNAME.conf"


#functions
#debug
_debug()
{
	echo "$@" 1>&2
	"$@"
}


#error
_error()
{
	echo "$PROGNAME: $@" 1>&2
	return 2
}


#edgebsd-tls
_edgebsd_tls()
{
	shift $((OPTIND - 1))
	if [ $# -eq 0 ]; then
		_usage
		return $?
	fi
	command="$1"
	shift
	case "$command" in
		create|renew)
			"_edgebsd_tls_$command" "$@"
			return $?
			;;
		*)
			_usage "$command: Unknown command"
			return $?
			;;
	esac
}

_edgebsd_tls_create()
{
	while getopts "O:" name; do
		case "$name" in
			O)
				eval "${OPTARG%%=*}"="${OPTARG#*=}"
				;;
			*)
				_usage
				return $?
				;;
		esac
	done
	shift $((OPTIND - 1))
	if [ $# -eq 0 ]; then
		_usage "create: At least one hostname is required"
		return $?
	fi
	#FIXME
	return 2
}

_edgebsd_tls_renew()
{
	all=0

	while getopts "O:a" name; do
		case "$name" in
			O)
				eval "${OPTARG%%=*}"="${OPTARG#*=}"
				;;
			a)
				all=1
				;;
			*)
				_usage
				return $?
				;;
		esac
	done
	shift $((OPTIND - 1))
	if [ $# -eq 0 -a $all -eq 0 ]; then
		_usage "renew: At least one hostname is required"
		return $?
	fi
	#FIXME
	return 2
}


#usage
_usage()
{
	[ $# -ge 1 ] && echo "$PROGNAME: $@" 1>&2
	echo "Usage: $PROGNAME command [options...]" 1>&2
	echo 1>&2
	echo "Commands supported:" 1>&2
	echo "  create" 1>&2
	echo "  renew [-a]	Renew one or more TLS certificates" 1>&2
	return 1
}


#main
_edgebsd_tls "$@"
